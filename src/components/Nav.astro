---
import type { AuthUser } from '../utils/auth';

interface Props {
  user?: AuthUser | null;
}

const { user } = Astro.props;

const navLinks = [
  { href: '/manifesto', label: 'Manifesto' },
  { href: '/why', label: 'Why' },
  { href: '/learn', label: 'Guides' },
  { href: '/ordinances', label: 'Ordinances' },
  { href: '/wall', label: 'Wall' },
  { href: '/blog', label: 'Blog' },
];
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm border-b border-earth-200">
  <div class="container">
    <nav class="flex items-center justify-between h-16" aria-label="Main navigation">
      <a href="/" class="flex items-center gap-2 text-brand-800 hover:text-brand-600 transition-colors">
        <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="8" fill="currentColor" class="text-brand-500" />
          <path d="M8 16c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="16" cy="12" r="2" fill="white"/>
          <rect x="10" y="21" width="12" height="3" rx="1.5" fill="#D97706"/>
        </svg>
        <span class="font-display font-bold text-xl hidden sm:inline">Quiet The Mowers</span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="px-3 py-2 rounded-lg text-sm font-medium text-earth-700 hover:text-brand-700 hover:bg-brand-50 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3">
        {user ? (
          <>
            <a href="/dashboard" class="text-sm font-medium text-earth-600 hover:text-brand-700 hidden sm:inline-flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-brand-100 flex items-center justify-center text-brand-700 font-bold text-xs">
                {(user.displayName || 'U').charAt(0).toUpperCase()}
              </div>
              <span>{user.displayName || 'Dashboard'}</span>
            </a>
            <a href="/campaigns/new" class="btn-accent text-sm px-4 py-2">
              Start a Campaign
            </a>
            <a href="/api/auth/sign-out" class="text-sm text-earth-500 hover:text-earth-700 px-2">
              Sign Out
            </a>
          </>
        ) : (
          <>
            <a href="/campaigns" class="btn-primary text-sm px-4 py-2 hidden sm:inline-flex">
              Find a Campaign
            </a>
            <a href="/sign-in" class="text-sm font-medium text-brand-700 hover:text-brand-900 px-3 py-2">
              Sign In
            </a>
            <a href="/campaigns/new" class="btn-accent text-sm px-4 py-2">
              Start One
            </a>
          </>
        )}

        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-earth-600 hover:bg-earth-100"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </nav>

    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-earth-200 mt-0">
      <div class="flex flex-col gap-1 pt-3">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="px-3 py-2 rounded-lg text-sm font-medium text-earth-700 hover:text-brand-700 hover:bg-brand-50 transition-colors"
          >
            {link.label}
          </a>
        ))}
        {user ? (
          <>
            <a href="/dashboard" class="px-3 py-2 rounded-lg text-sm font-medium text-brand-700 hover:bg-brand-50 transition-colors">
              Dashboard
            </a>
            <a href="/api/auth/sign-out" class="px-3 py-2 rounded-lg text-sm font-medium text-earth-500 hover:bg-earth-50 transition-colors">
              Sign Out
            </a>
          </>
        ) : (
          <a href="/campaigns" class="btn-primary text-sm mt-2 w-full justify-center">
            Find a Campaign
          </a>
        )}
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
