---
import { UserButton, SignInButton } from '@clerk/astro/components';

const navLinks = [
  { href: '/manifesto', label: 'Manifesto' },
  { href: '/why', label: 'Why' },
  { href: '/learn', label: 'Guides' },
  { href: '/ordinances', label: 'Ordinances' },
  { href: '/wall', label: 'Wall' },
  { href: '/blog', label: 'Blog' },
];
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm border-b border-earth-200">
  <div class="container">
    <nav class="flex items-center justify-between h-16" aria-label="Main navigation">
      <a href="/" class="flex items-center gap-2 text-brand-800 hover:text-brand-600 transition-colors">
        <img src="/images/logo-header.png" alt="Quiet The Mowers" class="h-8 w-auto" />
        <span class="font-display font-bold text-xl hidden sm:inline">Quiet The Mowers</span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="px-3 py-2 rounded-lg text-sm font-medium text-earth-700 hover:text-brand-700 hover:bg-brand-50 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3">
        <SignInButton mode="modal">
          <a href="/sign-in" class="text-sm font-medium text-brand-700 hover:text-brand-900 px-3 py-2 cursor-pointer hidden">
            Sign In
          </a>
        </SignInButton>
        <a href="/dashboard" class="text-sm font-medium text-brand-700 hover:text-brand-900 px-3 py-2">
          Dashboard
        </a>
        <a href="/campaigns/new" class="btn-accent text-sm px-4 py-2">
          Start One
        </a>
        <div class="ml-2">
          <UserButton afterSignOutUrl="/" />
        </div>

        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-earth-600 hover:bg-earth-100"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </nav>

    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-earth-200 mt-0">
      <div class="flex flex-col gap-1 pt-3">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="px-3 py-2 rounded-lg text-sm font-medium text-earth-700 hover:text-brand-700 hover:bg-brand-50 transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a href="/dashboard" class="px-3 py-2 rounded-lg text-sm font-medium text-brand-700 hover:bg-brand-50 transition-colors">
          Dashboard
        </a>
        <a href="/campaigns/new" class="btn-accent text-sm mt-2 w-full justify-center">
          Start a Campaign
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
