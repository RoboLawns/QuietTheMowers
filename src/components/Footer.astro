---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-950 text-earth-200">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 text-white mb-4">
          <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="#4e8c42"/>
            <path d="M8 16c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            <circle cx="16" cy="12" r="2" fill="white"/>
            <rect x="10" y="21" width="12" height="3" rx="1.5" fill="#D97706"/>
          </svg>
          <span class="font-display font-bold text-xl">Quiet The Mowers</span>
        </a>
        <p class="text-earth-300 text-sm leading-relaxed mb-6">
          Turning the #QuietTheMowers hashtag into local policy change.
          A civic-tech platform for quieter neighborhoods.
        </p>
        <div class="flex gap-3">
          <a href="https://x.com/QuietTheMowers" class="text-earth-400 hover:text-white transition-colors" aria-label="X (Twitter)">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://facebook.com/QuietTheMowers" class="text-earth-400 hover:text-white transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://instagram.com/QuietTheMowers" class="text-earth-400 hover:text-white transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Platform</h3>
        <ul class="space-y-3">
          <li><a href="/campaigns" class="text-earth-300 hover:text-white transition-colors text-sm">Find Campaigns</a></li>
          <li><a href="/campaigns/new" class="text-earth-300 hover:text-white transition-colors text-sm">Start a Campaign</a></li>
          <li><a href="/measure" class="text-earth-300 hover:text-white transition-colors text-sm">Measure Noise</a></li>
          <li><a href="/ordinances" class="text-earth-300 hover:text-white transition-colors text-sm">Ordinance Library</a></li>
          <li><a href="/wins" class="text-earth-300 hover:text-white transition-colors text-sm">Wins Map</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Learn</h3>
        <ul class="space-y-3">
          <li><a href="/manifesto" class="text-earth-300 hover:text-white transition-colors text-sm">The Manifesto</a></li>
          <li><a href="/why" class="text-earth-300 hover:text-white transition-colors text-sm">Why This Matters</a></li>
          <li><a href="/learn" class="text-earth-300 hover:text-white transition-colors text-sm">Guides</a></li>
          <li><a href="/blog" class="text-earth-300 hover:text-white transition-colors text-sm">Blog</a></li>
          <li><a href="/wall" class="text-earth-300 hover:text-white transition-colors text-sm">Testimonial Wall</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Stay Connected</h3>
        <p class="text-earth-300 text-sm mb-4">
          Get campaign wins, new ordinances, and quiet morning stories in your inbox.
        </p>
        <form id="waitlist-form" class="flex gap-2">
          <input
            id="waitlist-email"
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="flex-1 rounded-lg bg-brand-900 border border-brand-700 px-4 py-2.5 text-sm text-white placeholder:text-earth-400 focus:outline-none focus:border-brand-400"
          />
          <button type="submit" class="btn-accent text-sm px-4 py-2.5 whitespace-nowrap">
            Join
          </button>
        </form>
        <p id="waitlist-msg" class="text-brand-300 text-sm mt-2 hidden">You're on the list! We'll be in touch.</p>
        <div class="mt-6 space-y-2">
          <a href="/about" class="block text-earth-400 hover:text-white transition-colors text-sm">About</a>
          <a href="/contact" class="block text-earth-400 hover:text-white transition-colors text-sm">Contact</a>
          <a href="/share" class="block text-earth-400 hover:text-white transition-colors text-sm">Shareable Assets</a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-brand-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-earth-400 text-sm">
        &copy; {currentYear} Quiet The Mowers. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-earth-400 hover:text-white transition-colors text-sm">Privacy</a>
        <a href="/terms" class="text-earth-400 hover:text-white transition-colors text-sm">Terms</a>
        <a href="https://github.com/QuietTheMowers" class="text-earth-400 hover:text-white transition-colors text-sm">GitHub</a>
      </div>
    </div>
  </div>
</footer>

<script>
  document.getElementById('waitlist-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (document.getElementById('waitlist-email') as HTMLInputElement)?.value;
    if (email) {
      // TODO: Phase 2 — submit to Resend API or D1
      console.log('Waitlist signup:', email);
      (e.target as HTMLFormElement).classList.add('hidden');
      document.getElementById('waitlist-msg')?.classList.remove('hidden');
    }
  });
</script>
