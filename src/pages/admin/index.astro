---
import Layout from '../../layouts/Layout.astro';
import { getCurrentUser, type AuthUser } from '../../utils/auth';
import { getDBFromLocals } from '../../utils/db';
import { env } from 'cloudflare:workers';

export const prerender = false;

const user = await getCurrentUser(Astro.locals, env) as AuthUser | null;

if (!user || user.role !== 'admin') {
  return new Response(null, { status: 302, headers: { Location: '/' } });
}

const db = getDB(env);

const pendingTestimonials = db.prepare('SELECT * FROM testimonials WHERE status = ? ORDER BY created_at DESC').bind('pending').all();
const pendingComments = db.prepare('SELECT c.*, u.display_name as author_name FROM comments c LEFT JOIN users u ON c.user_id = u.id WHERE c.status = ? ORDER BY c.created_at DESC').bind('flagged').all();
const devicesData = db.prepare('SELECT * FROM devices ORDER BY status, created_at DESC').all();
const rentalRequests = db.prepare('SELECT rr.*, u.display_name as requester_name, u.email as requester_email FROM rental_requests rr LEFT JOIN users u ON rr.user_id = u.id ORDER BY rr.created_at DESC LIMIT 20').all();
const stats = db.prepare(`
  SELECT
    (SELECT COUNT(*) FROM users) as total_users,
    (SELECT COUNT(*) FROM campaigns) as total_campaigns,
    (SELECT COUNT(*) FROM signatures) as total_signatures,
    (SELECT COUNT(*) FROM measurements) as total_measurements,
    (SELECT COUNT(*) FROM testimonials) as total_testimonials
`).first() as any;

let message = '';
let messageType = 'success';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  try {
    if (action === 'approve_testimonial') {
      db.prepare('UPDATE testimonials SET status = ?, approved_at = datetime(\'now\') WHERE id = ?')
        .bind('approved', formData.get('id')).run();
      message = 'Testimonial approved.';
    } else if (action === 'reject_testimonial') {
      db.prepare('UPDATE testimonials SET status = ? WHERE id = ?')
        .bind('rejected', formData.get('id')).run();
      message = 'Testimonial rejected.';
    } else if (action === 'feature_testimonial') {
      db.prepare('UPDATE testimonials SET featured = CASE WHEN featured = 1 THEN 0 ELSE 1 END WHERE id = ?')
        .bind(formData.get('id')).run();
      message = 'Featured toggled.';
    } else if (action === 'approve_comment') {
      db.prepare('UPDATE comments SET status = ? WHERE id = ?')
        .bind('visible', formData.get('id')).run();
      message = 'Comment approved.';
    } else if (action === 'remove_comment') {
      db.prepare('UPDATE comments SET status = ? WHERE id = ?')
        .bind('removed', formData.get('id')).run();
      message = 'Comment removed.';
    } else if (action === 'update_rental') {
      const status = formData.get('rental_status')?.toString();
      const rentalId = formData.get('rental_id')?.toString();
      if (status && rentalId) {
        db.prepare('UPDATE rental_requests SET status = ?, updated_at = datetime(\'now\') WHERE id = ?')
          .bind(status, rentalId).run();
        message = 'Rental request updated.';
      }
    }

    if (message) {
      return new Response(null, { status: 302, headers: { Location: `/admin?msg=${encodeURIComponent(message)}` } });
    }
  } catch {
    message = 'Action failed.';
    messageType = 'error';
  }
}
---

<Layout title="Admin" description="Admin dashboard for Quiet The Mowers." user={user}>

<section class="section">
  <div class="container-narrow">
    <h1 class="text-4xl font-display font-bold text-brand-900 mb-2">Admin Dashboard</h1>
    <p class="text-earth-500 mb-10">Welcome, {user.displayName}.</p>

    {message && (
      <div class={`rounded-xl p-4 mb-8 text-sm text-center ${messageType === 'error' ? 'bg-red-50 border border-red-200 text-red-700' : 'bg-green-50 border border-green-200 text-green-700'}`}>
        {message}
      </div>
    )}

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-10">
      {[
        { label: 'Users', value: stats?.total_users || 0 },
        { label: 'Campaigns', value: stats?.total_campaigns || 0 },
        { label: 'Signatures', value: stats?.total_signatures || 0 },
        { label: 'Measurements', value: stats?.total_measurements || 0 },
        { label: 'Testimonials', value: stats?.total_testimonials || 0 },
      ].map(s => (
        <div class="bg-white border border-earth-200 rounded-xl p-3 text-center">
          <div class="text-2xl font-display font-bold text-brand-600">{s.value}</div>
          <div class="text-xs text-earth-500">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Moderation: Testimonials -->
    <div class="bg-white border border-earth-200 rounded-2xl p-8 mb-8">
      <h2 class="text-xl font-display font-bold text-brand-900 mb-6">
        Testimonial Moderation ({pendingTestimonials.results?.length || 0} pending)
      </h2>
      {Array.isArray(pendingTestimonials.results) && pendingTestimonials.results.length > 0 ? (
        <div class="space-y-4">
          {pendingTestimonials.results.map((t: any) => (
            <div class="border border-earth-200 rounded-xl p-4">
              <p class="font-semibold text-brand-900 mb-1">{t.title}</p>
              <p class="text-sm text-earth-600 mb-3">{t.body_markdown?.slice(0, 300)}...</p>
              <p class="text-xs text-earth-400 mb-3">by {t.display_name} · {t.location_city}, {t.location_state} · {new Date(t.created_at).toLocaleDateString()}</p>
              <form method="POST" class="flex gap-2">
                <input type="hidden" name="id" value={t.id} />
                <button type="submit" name="action" value="approve_testimonial" class="btn-primary text-xs px-3 py-1.5">Approve</button>
                <button type="submit" name="action" value="reject_testimonial" class="btn-secondary text-xs px-3 py-1.5">Reject</button>
              </form>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-sm text-earth-400 text-center py-6">No pending testimonials.</p>
      )}

      <h3 class="font-semibold text-brand-900 mt-8 mb-4">Approved Testimonials</h3>
      {Array.isArray(db.prepare('SELECT * FROM testimonials WHERE status = ? ORDER BY created_at DESC LIMIT 20').bind('approved').all().results) && (
        <div class="space-y-2">
          {db.prepare('SELECT * FROM testimonials WHERE status = ? ORDER BY created_at DESC LIMIT 20').bind('approved').all().results.map((t: any) => (
            <div class="flex items-center justify-between text-sm py-2 px-3 bg-earth-50 rounded-lg">
              <span class="truncate mr-2">{t.title} <span class="text-earth-400">by {t.display_name}</span></span>
              <form method="POST" class="shrink-0">
                <input type="hidden" name="id" value={t.id} />
                <button type="submit" name="action" value="feature_testimonial" class="text-xs text-accent-600 hover:text-accent-800">
                  {t.featured ? 'Unfeature' : 'Feature'}
                </button>
              </form>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Moderation: Comments -->
    <div class="bg-white border border-earth-200 rounded-2xl p-8 mb-8">
      <h2 class="text-xl font-display font-bold text-brand-900 mb-6">
        Flagged Comments ({pendingComments.results?.length || 0})
      </h2>
      {Array.isArray(pendingComments.results) && pendingComments.results.length > 0 ? (
        <div class="space-y-3">
          {pendingComments.results.map((c: any) => (
            <div class="border border-earth-200 rounded-lg p-3">
              <p class="text-sm text-earth-700 mb-2">{c.body}</p>
              <p class="text-xs text-earth-400 mb-2">by {c.author_name} · {new Date(c.created_at).toLocaleDateString()}</p>
              <form method="POST" class="flex gap-2">
                <input type="hidden" name="id" value={c.id} />
                <button type="submit" name="action" value="approve_comment" class="btn-primary text-xs px-3 py-1.5">Approve</button>
                <button type="submit" name="action" value="remove_comment" class="text-xs px-3 py-1.5 text-red-600 hover:text-red-800">Remove</button>
              </form>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-sm text-earth-400 text-center py-6">No flagged comments.</p>
      )}
    </div>

    <!-- Device Inventory -->
    <div class="bg-white border border-earth-200 rounded-2xl p-8 mb-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-display font-bold text-brand-900">Device Inventory</h2>
        <a href="/admin/devices/new" class="btn-primary text-xs px-3 py-1.5">Add Device</a>
      </div>
      {Array.isArray(devicesData.results) && devicesData.results.length > 0 ? (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b-2 border-earth-200 text-left">
                <th class="py-3 pr-4 font-semibold">Serial #</th>
                <th class="py-3 pr-4 font-semibold">Model</th>
                <th class="py-3 pr-4 font-semibold">Status</th>
                <th class="py-3 pr-4 font-semibold">Calibration</th>
                <th class="py-3 font-semibold">Holder</th>
              </tr>
            </thead>
            <tbody>
              {devicesData.results.map((d: any) => (
                <tr class="border-b border-earth-100 text-earth-600">
                  <td class="py-2 pr-4 font-mono text-xs">{d.serial_number}</td>
                  <td class="py-2 pr-4">{d.model || '-'}</td>
                  <td class="py-2 pr-4"><span class={`text-xs px-2 py-0.5 rounded-full ${
                    d.status === 'available' ? 'bg-green-100 text-green-700' :
                    d.status === 'rented' ? 'bg-accent-100 text-accent-700' :
                    'bg-earth-100 text-earth-600'
                  }`}>{d.status}</span></td>
                  <td class="py-2 pr-4 text-xs">{d.calibration_date || 'Not set'}</td>
                  <td class="py-2 text-xs">{d.current_holder_id || '-'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="text-sm text-earth-400 text-center py-6">No devices in inventory.</p>
      )}
    </div>

    <!-- Rental Requests -->
    <div class="bg-white border border-earth-200 rounded-2xl p-8">
      <h2 class="text-xl font-display font-bold text-brand-900 mb-6">
        Rental Requests ({rentalRequests.results?.length || 0})
      </h2>
      {Array.isArray(rentalRequests.results) && rentalRequests.results.length > 0 ? (
        <div class="space-y-4">
          {rentalRequests.results.map((r: any) => (
            <div class="border border-earth-200 rounded-lg p-4">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                <span class="font-semibold text-brand-900">{r.requester_name || 'Unknown'}</span>
                <span class={`text-xs px-2 py-0.5 rounded-full ${
                  r.status === 'pending' ? 'bg-earth-100 text-earth-600' :
                  r.status === 'approved' ? 'bg-green-100 text-green-700' :
                  r.status === 'shipped' ? 'bg-accent-100 text-accent-700' :
                  'bg-earth-100 text-earth-600'
                }`}>{r.status}</span>
              </div>
              <p class="text-sm text-earth-600 mb-1">{r.requested_start} to {r.requested_end}</p>
              <p class="text-xs text-earth-400 mb-1">{r.intended_use?.slice(0, 100)}</p>
              <p class="text-xs text-earth-400 mb-3">{r.requester_email} · Created {new Date(r.created_at).toLocaleDateString()}</p>
              <form method="POST" class="flex gap-2">
                <input type="hidden" name="rental_id" value={r.id} />
                <select name="rental_status" class="rounded-lg border border-earth-300 px-2 py-1 text-xs">
                  <option value="pending">Pending</option>
                  <option value="approved">Approved</option>
                  <option value="shipped">Shipped</option>
                  <option value="returned">Returned</option>
                  <option value="cancelled">Cancelled</option>
                </select>
                <button type="submit" name="action" value="update_rental" class="btn-primary text-xs px-2 py-1">Update</button>
              </form>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-sm text-earth-400 text-center py-6">No rental requests yet.</p>
      )}
    </div>
  </div>
</section>

</Layout>
