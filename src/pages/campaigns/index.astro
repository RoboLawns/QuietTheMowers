---
import Layout from '../../layouts/Layout.astro';
import { getCurrentUser, type AuthUser } from '../../utils/auth';
import { getDBFromLocals } from '../../utils/db';
import { env } from 'cloudflare:workers';

export const prerender = false;

const db = getDB(env);
const user = await getCurrentUser(Astro.locals, env) as AuthUser | null;

// Fetch campaigns from DB
const campaignsResult = db.prepare(`
  SELECT c.*, u.display_name as organizer_name,
    (SELECT COUNT(*) FROM signatures WHERE campaign_id = c.id) as signature_count
  FROM campaigns c
  LEFT JOIN users u ON c.organizer_id = u.id
  WHERE c.status != 'draft'
  ORDER BY c.created_at DESC
`).all();

const campaigns = (campaignsResult.results || []) as any[];

const statusLabels: Record<string, string> = {
  draft: 'Draft',
  active: 'Active',
  won: 'Won!',
  closed: 'Closed',
};

const templateLabels: Record<string, string> = {
  hours_restriction: 'Hours Restriction',
  gas_blower_ban: 'Gas Blower Ban',
  hoa_rules: 'HOA Rule Change',
  custom: 'Custom',
};
---

<Layout title="Find Campaigns" description="Browse and support active campaigns in your area. Filter by location, type, and status." user={user}>

<section class="section">
  <div class="container-narrow">
    <div class="text-center mb-12">
      <p class="text-brand-600 font-semibold text-sm tracking-wider uppercase mb-4">Campaigns</p>
      <h1 class="text-4xl md:text-6xl font-display font-bold text-brand-900 leading-tight mb-4">
        Find a Campaign
      </h1>
      <p class="text-xl text-earth-500 max-w-2xl mx-auto">
        Browse active campaigns, sign petitions, and support organizers making change in their communities.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-4 mb-12">
      <a href="/campaigns/new" class="btn-primary">
        Start Your Own Campaign
      </a>
    </div>

    {campaigns.length === 0 ? (
      <div class="text-center py-16">
        <p class="text-xl text-earth-400 mb-4">No campaigns yet.</p>
        <p class="text-earth-500 mb-8">Be the first to start one in your community.</p>
        <a href="/campaigns/new" class="btn-primary">Start a Campaign</a>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 gap-6">
        {campaigns.map((c: any) => (
          <a
            href={`/campaigns/${c.slug}`}
            class="block bg-white border border-earth-200 rounded-xl overflow-hidden hover:border-brand-300 hover:shadow-md transition-all"
          >
            <div class="p-6">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${
                  c.status === 'active' ? 'bg-green-100 text-green-700' :
                  c.status === 'won' ? 'bg-accent-100 text-accent-700' :
                  'bg-earth-100 text-earth-600'
                }`}>
                  {statusLabels[c.status] || c.status}
                </span>
                <span class="text-xs bg-brand-50 text-brand-700 px-2 py-0.5 rounded-full">
                  {templateLabels[c.template_type] || c.template_type}
                </span>
              </div>

              <h2 class="text-xl font-display font-bold text-brand-900 mb-2">{c.title}</h2>
              <p class="text-sm text-earth-500 mb-4">
                {c.target_name || c.location_city || 'Local campaign'}
                {c.location_state ? `, ${c.location_state}` : ''}
              </p>

              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2 text-sm">
                  <div class="w-6 h-6 rounded-full bg-brand-100 flex items-center justify-center text-brand-700 font-bold text-[10px]">
                    {(c.organizer_name || 'O').charAt(0).toUpperCase()}
                  </div>
                  <span class="text-earth-600">{c.organizer_name || 'Organizer'}</span>
                </div>

                <div class="text-right">
                  <div class="text-lg font-bold text-brand-600">{c.signature_count || 0}</div>
                  <div class="text-xs text-earth-400">of {c.goal_signatures} signatures</div>
                </div>
              </div>

              <div class="mt-4 w-full bg-earth-200 rounded-full h-1.5">
                <div
                  class="bg-brand-500 h-1.5 rounded-full transition-all"
                  style={`width: ${Math.min(100, ((c.signature_count || 0) / (c.goal_signatures || 1)) * 100)}%`}
                ></div>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    {campaigns.length > 0 && (
      <div class="text-center mt-12">
        <p class="text-earth-500 mb-4">Don't see your campaign?</p>
        <a href="/campaigns/new" class="btn-accent">Start One Now</a>
      </div>
    )}
  </div>
</section>

</Layout>
