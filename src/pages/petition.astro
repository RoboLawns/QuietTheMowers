---
import Layout from '../layouts/Layout.astro';
import { getAuthFromRequest, type AuthUser } from '../utils/auth';
import { getDB } from '../utils/db';
import { env } from 'cloudflare:workers';
import { sendSignatureConfirmation } from '../utils/email';
import { sendVerificationEmail, generateToken } from '../utils/verification';

export const prerender = false;

const db = getDB(env);
const user = getAuthFromRequest(Astro.request, env) as AuthUser | null;

// Check if national petition exists, create if not
let campaign = db.prepare("SELECT * FROM campaigns WHERE slug = 'national-quiet-neighborhoods-petition'").first() as any;

if (!campaign) {
  const id = crypto.randomUUID();
  db.prepare(`INSERT INTO campaigns (id, slug, organizer_id, title, template_type, target_jurisdiction, target_name, location_city, location_state, story_markdown, goal_signatures, status) VALUES (?, ?, 'u_seed_organizer', ?, 'custom', 'state', 'All 50 States', 'Nationwide', 'US', ?, 10000, 'active')`)
    .bind(id, 'national-quiet-neighborhoods-petition', 'The National Quiet Neighborhoods Petition', 'I believe every American deserves the right to peace and quiet in their own home. Gas-powered lawn equipment is the last unregulated noise pollutant in our neighborhoods. I support local and national efforts to phase out gas-powered lawn equipment in favor of quiet, clean, electric alternatives. This is about health, quality of life, and the simple right to hear birdsong on a Saturday morning.').run();
  campaign = db.prepare("SELECT * FROM campaigns WHERE slug = 'national-quiet-neighborhoods-petition'").first() as any;
}

const sigCount = db.prepare('SELECT COUNT(*) as count FROM signatures WHERE campaign_id = ?').bind(campaign?.id || '').first() as any;
const totalSignatures = sigCount?.count || 0;

// Check if current user already signed
let alreadySigned = false;
if (user) {
  const existing = db.prepare('SELECT id FROM signatures WHERE campaign_id = ? AND email = ?').bind(campaign?.id || '', user.email).first();
  alreadySigned = Boolean(existing);
}

let justSigned = false;
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const name = formData.get('name')?.toString()?.trim();
    const email = formData.get('email')?.toString()?.trim();
    const zip = formData.get('zip')?.toString()?.trim();

    if (!name || !email) {
      error = 'Name and email are required.';
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      error = 'Please enter a valid email address.';
    } else {
      const existing = db.prepare('SELECT id FROM signatures WHERE email = ? AND campaign_id = ?').bind(email, campaign?.id).first();
      if (existing) {
        error = 'You have already signed this petition. Thank you!';
      } else {
        const sid = crypto.randomUUID();
        db.prepare('INSERT INTO signatures (id, campaign_id, name, email, zip, display_publicly) VALUES (?, ?, ?, ?, ?, 1)')
          .bind(sid, campaign?.id, name, email, zip || null).run();
        justSigned = true;

        // Generate verification token (7-day expiry)
        const verifyToken = generateToken();
        const tokenId = crypto.randomUUID();
        const expires = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString();
        db.prepare('INSERT INTO verification_tokens (id, email, signature_id, token, type, expires_at) VALUES (?, ?, ?, ?, ?, ?)')
          .bind(tokenId, email, sid, verifyToken, 'signature', expires).run();

        // Send verification + confirmation emails
        sendVerificationEmail(env, email, name, verifyToken, campaign.title).catch(() => {});
        sendSignatureConfirmation(env, email, name, campaign.title, campaign.slug).catch(() => {});
      }
    }
  } catch (e: any) {
    error = 'Something went wrong. Please try again.';
  }
}

const goal = 10000;
const progress = Math.min(100, Math.round((totalSignatures / goal) * 100));
---

<Layout title="Sign the National Petition" description="Sign the nationwide petition to support quieter neighborhoods. Every signature counts." user={user}>

<section class="section">
  <div class="container-narrow">
    {justSigned ? (
      <div class="text-center py-16">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h1 class="text-3xl font-display font-bold text-brand-900 mb-4">Thank You for Signing!</h1>
        <p class="text-lg text-earth-600 mb-6 max-w-md mx-auto">
          You're now part of the movement. Share this petition with your neighbors.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/dashboard" class="btn-primary">Go to Dashboard</a>
          <button onclick={`navigator.clipboard.writeText('${new URL('/petition', Astro.site).href}')`} class="btn-secondary">Share This Petition</button>
        </div>
      </div>
    ) : (
      <>
        <div class="text-center mb-10">
          <h1 class="text-4xl font-display font-bold text-brand-900 mb-4">
            The National Quiet Neighborhoods Petition
          </h1>
          <p class="text-xl text-earth-500 max-w-2xl mx-auto">
            One signature. One movement. Every American deserves quiet mornings.
          </p>
        </div>

        <div class="bg-white border-2 border-brand-200 rounded-2xl p-8 mb-8">
          <div class="flex items-end justify-between mb-6">
            <div>
              <div class="text-5xl font-display font-bold text-brand-600">{totalSignatures.toLocaleString()}</div>
              <div class="text-earth-500">signatures of {goal.toLocaleString()} goal</div>
            </div>
            <div class="text-right">
              <div class="text-2xl font-bold text-brand-600">{progress}%</div>
              <div class="text-xs text-earth-400">complete</div>
            </div>
          </div>
          <div class="w-full bg-earth-200 rounded-full h-3 mb-8">
            <div class="bg-brand-500 h-3 rounded-full transition-all" style={`width: ${progress}%`}></div>
          </div>

          {error && (
            <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6 text-red-700 text-sm text-center">{error}</div>
          )}

          {alreadySigned && !error ? (
            <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-green-700 text-sm text-center mb-6">
              You've already signed this petition. Thank you for your support!
              <div class="mt-3">
                <a href="/dashboard" class="btn-primary text-sm px-4 py-2">Go to Dashboard</a>
              </div>
            </div>
          ) : !alreadySigned && (
            <form method="POST" class="space-y-4 max-w-md mx-auto">
              <div>
                <label for="name" class="block text-sm font-medium text-earth-700 mb-1">Full Name *</label>
                <input type="text" id="name" name="name" required placeholder="Your name" class="w-full rounded-lg border border-earth-300 px-4 py-2.5 text-earth-900 placeholder:text-earth-400 focus:outline-none focus:ring-2 focus:ring-brand-500" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-earth-700 mb-1">Email *</label>
                <input type="email" id="email" name="email" required placeholder="you@example.com" class="w-full rounded-lg border border-earth-300 px-4 py-2.5 text-earth-900 placeholder:text-earth-400 focus:outline-none focus:ring-2 focus:ring-brand-500" />
                <p class="text-xs text-earth-400 mt-1">Never displayed publicly.</p>
              </div>
              <div>
                <label for="zip" class="block text-sm font-medium text-earth-700 mb-1">ZIP Code</label>
                <input type="text" id="zip" name="zip" pattern="[0-9]{5}" placeholder="e.g. 80303" class="w-full rounded-lg border border-earth-300 px-4 py-2.5 text-earth-900 placeholder:text-earth-400 focus:outline-none focus:ring-2 focus:ring-brand-500" />
              </div>
              <button type="submit" class="btn-primary w-full text-lg py-4">Sign the Petition</button>
            </form>
          )}
        </div>

        <div class="prose max-w-2xl mx-auto">
          <h2>What You're Signing</h2>
          <p>By signing, you support:</p>
          <ul>
            <li>Local ordinances that restrict gas-powered lawn equipment to reasonable hours</li>
            <li>HOA rule changes that allow or require electric equipment</li>
            <li>Incentives and rebates for electric lawn equipment conversion</li>
            <li>Recognition of noise pollution as a public health issue</li>
          </ul>
          <p>This is a baseline petition — a show of public support. When you're ready to make change locally, <a href="/campaigns/new">start your own campaign</a> targeting your specific HOA, city, or county.</p>
        </div>
      </>
    )}

    {!justSigned && (
      <div class="text-center mt-12">
        <p class="text-earth-500 mb-4">Ready to do more?</p>
        <a href="/campaigns/new" class="btn-accent text-lg px-8 py-4">Start a Local Campaign</a>
      </div>
    )}
  </div>
</section>

</Layout>
