---
import Layout from '../../layouts/Layout.astro';
import { getCurrentUser, type AuthUser } from '../../utils/auth';
import { getDBFromLocals } from '../../utils/db';

export const prerender = false;

const db = getDBFromLocals(Astro.locals);
const user = await getCurrentUser(Astro.locals) as AuthUser | null;

// Get won campaigns as wins
const wins = db.prepare(`
  SELECT c.*, u.display_name as organizer_name
  FROM campaigns c
  LEFT JOIN users u ON c.organizer_id = u.id
  WHERE c.status = 'won'
  ORDER BY c.updated_at DESC
`).all();

// Stats
const stats = db.prepare(`
  SELECT
    (SELECT COUNT(*) FROM campaigns WHERE status = 'won') as total_wins,
    (SELECT COUNT(DISTINCT location_state) FROM campaigns WHERE status = 'won') as states,
    (SELECT COUNT(*) FROM signatures) as total_signatures
`).first() as any;

const jurisdictionLabels: Record<string, string> = {
  city: 'City', hoa: 'HOA', county: 'County', state: 'State',
};
---

<Layout title="Wins Map" description="Cities, neighborhoods, and HOAs that have changed their rules. Each pin is a story." user={user}>

<section class="section">
  <div class="container-narrow">
    <div class="text-center mb-12">
      <p class="text-brand-600 font-semibold text-sm tracking-wider uppercase mb-4">Wins</p>
      <h1 class="text-4xl md:text-6xl font-display font-bold text-brand-900 leading-tight mb-4">
        The Wins Map
      </h1>
      <p class="text-xl text-earth-500 max-w-2xl mx-auto">
        Cities, neighborhoods, and HOAs that have changed their rules.
        Every pin is a proof point that change is possible.
      </p>
    </div>

    <div class="grid grid-cols-3 gap-4 mb-12">
      <div class="bg-white border border-earth-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-display font-bold text-accent-500">{stats?.total_wins || 0}</div>
        <div class="text-sm text-earth-500 mt-1">Policy Wins</div>
      </div>
      <div class="bg-white border border-earth-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-display font-bold text-accent-500">{stats?.states || 0}</div>
        <div class="text-sm text-earth-500 mt-1">States</div>
      </div>
      <div class="bg-white border border-earth-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-display font-bold text-accent-500">{stats?.total_signatures || 0}</div>
        <div class="text-sm text-earth-500 mt-1">Signatures</div>
      </div>
    </div>

    <blockquote class="bg-brand-50 border border-brand-200 rounded-2xl p-6 mb-12 text-center">
      <p class="text-lg text-brand-800 font-display italic">
        "The movement has won in {stats?.total_wins || 0} places. Your neighborhood could be next."
      </p>
    </blockquote>

    {Array.isArray(wins.results) && wins.results.length > 0 ? (
      <div class="space-y-6">
        {wins.results.map((w: any) => (
          <a href={`/campaigns/${w.slug}`} class="block bg-white border border-earth-200 rounded-xl p-6 hover:border-accent-300 hover:shadow-md transition-all">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-5 h-5 text-accent-500 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  <h3 class="font-display font-bold text-brand-900 text-lg">{w.title}</h3>
                </div>
                <div class="flex flex-wrap gap-2 mb-3">
                  <span class="text-xs bg-accent-100 text-accent-700 px-2 py-0.5 rounded-full font-medium">Won!</span>
                  <span class="text-xs bg-earth-100 text-earth-600 px-2 py-0.5 rounded-full">
                    {w.location_city}{w.location_state ? `, ${w.location_state}` : ''}
                  </span>
                  <span class="text-xs bg-earth-100 text-earth-600 px-2 py-0.5 rounded-full">
                    {jurisdictionLabels[w.target_jurisdiction] || w.target_jurisdiction}
                  </span>
                </div>
                <p class="text-sm text-earth-600">
                  {w.target_name} &middot; Organized by {w.organizer_name || 'Unknown'}
                </p>
              </div>
              <span class="text-brand-600 text-sm font-medium shrink-0">View Story &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-16 bg-earth-50 rounded-2xl">
        <p class="text-xl text-earth-400 mb-4">No wins yet — be the first!</p>
        <p class="text-earth-500 mb-8">Every campaign that succeeds gets added here. The map grows with every win.</p>
        <a href="/campaigns/new" class="btn-primary">Start a Campaign</a>
      </div>
    )}

    <div class="mt-12 bg-white border border-earth-200 rounded-2xl p-8 text-center">
      <h2 class="text-xl font-display font-bold text-brand-900 mb-3">Know About a Missing Win?</h2>
      <p class="text-earth-500 mb-6">If your city, HOA, or county passed a rule that's not listed here, let us know.</p>
      <a href="/contact" class="btn-secondary">Submit a Win</a>
    </div>
  </div>
</section>

</Layout>
