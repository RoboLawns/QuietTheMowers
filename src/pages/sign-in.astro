---
import Layout from '../layouts/Layout.astro';
import { getCurrentUser } from '../utils/auth';

export const prerender = false;

const user = await getCurrentUser(Astro.locals);

if (user) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Sign In" description="Sign in to Quiet The Mowers">
  <section class="section">
    <div class="max-w-md mx-auto">
      <div class="text-center mb-10">
        <h1 class="text-3xl font-display font-bold text-brand-900 mb-3">Welcome Back</h1>
        <p class="text-earth-500">Sign in to manage your campaigns and track your impact.</p>
      </div>
      <div class="bg-white border border-earth-200 rounded-2xl p-8">
        <div id="clerk-component"></div>
      </div>
      <p class="text-center text-sm text-earth-400 mt-6">
        Don't have an account? <a href="/sign-up" class="text-brand-600 hover:text-brand-800 font-medium">Sign up</a>
      </p>
    </div>
  </section>
</Layout>

<script>
  const pubKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY;
  if (pubKey && !pubKey.includes('placeholder')) {
    const script = document.createElement('script');
    script.src = 'https://js.clerk.com/headless/headless.js';
    script.async = true;
    script.crossOrigin = 'anonymous';
    script.setAttribute('data-clerk-publishable-key', pubKey);
    document.head.appendChild(script);
    script.onload = () => {
      if (window.Clerk) {
        window.Clerk.load().then(() => {
          window.Clerk.mountSignIn(document.getElementById('clerk-component')!, {
            signUpUrl: '/sign-up',
            afterSignInUrl: '/dashboard',
          });
        });
      }
    };
  }
</script>