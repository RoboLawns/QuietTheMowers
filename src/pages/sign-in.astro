---
import Layout from '../layouts/Layout.astro';
import { getCurrentUser } from '../utils/auth';
import { SignIn } from '@clerk/astro/components';

export const prerender = false;

const user = await getCurrentUser(Astro.locals, env);

if (user) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Sign In" description="Sign in to Quiet The Mowers">
  <section class="section">
    <div class="max-w-md mx-auto">
      <div class="text-center mb-10">
        <h1 class="text-3xl font-display font-bold text-brand-900 mb-3">Welcome Back</h1>
        <p class="text-earth-500">Sign in to manage your campaigns and track your impact.</p>
      </div>
      <SignIn signUpUrl="/sign-up" afterSignInUrl="/dashboard" />
      <p class="text-center text-sm text-earth-400 mt-6">
        Don't have an account? <a href="/sign-up" class="text-brand-600 hover:text-brand-800 font-medium">Sign up</a>
      </p>
    </div>
  </section>
</Layout>