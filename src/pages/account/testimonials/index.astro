---
import Layout from '../../../layouts/Layout.astro';
import { getCurrentUser, type AuthUser } from '../../../utils/auth';
import { getDBFromLocals } from '../../../utils/db';
import { env } from 'cloudflare:workers';

export const prerender = false;

const user = await getCurrentUser(Astro.locals, env) as AuthUser | null;

if (!user) {
  return new Response(null, { status: 302, headers: { Location: '/sign-in?redirect=/account/testimonials' } });
}

const db = getDB(env);
const testimonials = db.prepare(`
  SELECT * FROM testimonials WHERE user_id = ? ORDER BY created_at DESC
`).bind(user.id).all();

let message = '';
let messageType = 'success';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();
  const testimonialId = formData.get('id')?.toString();

  if (action === 'delete' && testimonialId) {
    db.prepare('DELETE FROM testimonials WHERE id = ? AND user_id = ?').bind(testimonialId, user.id).run();
    message = 'Story deleted.';
    return new Response(null, { status: 302, headers: { Location: '/account/testimonials?msg=deleted' } });
  }

  if (action === 'edit' && testimonialId) {
    const title = formData.get('title')?.toString()?.trim();
    const body = formData.get('body_markdown')?.toString()?.trim();
    if (title && body) {
      db.prepare('UPDATE testimonials SET title = ?, body_markdown = ?, status = \'pending\' WHERE id = ? AND user_id = ?')
        .bind(title, body, testimonialId, user.id).run();
      message = 'Story updated and resubmitted for review.';
      return new Response(null, { status: 302, headers: { Location: '/account/testimonials?msg=updated' } });
    }
  }
}

const urlMsg = Astro.url.searchParams.get('msg');
if (urlMsg === 'deleted') message = 'Story deleted.';
if (urlMsg === 'updated') message = 'Story updated.';

const statusLabels: Record<string, string> = {
  pending: 'Pending Review',
  approved: 'Approved',
  rejected: 'Rejected',
};
---

<Layout title="My Testimonials" description="Manage your written testimonials." user={user}>

<section class="section">
  <div class="container-narrow">
    <a href="/dashboard" class="text-brand-600 text-sm font-medium hover:text-brand-800 mb-8 inline-flex items-center gap-1">
      &larr; Dashboard
    </a>

    <div class="flex items-center justify-between mb-10">
      <div>
        <h1 class="text-4xl font-display font-bold text-brand-900 mb-2">My Testimonials</h1>
        <p class="text-earth-500">{testimonials.results?.length || 0} stories written</p>
      </div>
      <a href="/wall/submit" class="btn-primary">Write New</a>
    </div>

    {message && (
      <div class="rounded-xl p-4 mb-8 text-sm text-center bg-green-50 border border-green-200 text-green-700">
        {message}
      </div>
    )}

    {Array.isArray(testimonials.results) && testimonials.results.length > 0 ? (
      <div class="space-y-4">
        {testimonials.results.map((t: any) => (
          <details class="bg-white border border-earth-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer hover:bg-earth-50 transition-colors list-none">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${
                    t.status === 'approved' ? 'bg-green-100 text-green-700' :
                    t.status === 'rejected' ? 'bg-red-100 text-red-700' :
                    'bg-earth-100 text-earth-600'
                  }`}>
                    {statusLabels[t.status] || t.status}
                  </span>
                  <span class="text-xs text-earth-400">{new Date(t.created_at).toLocaleDateString()}</span>
                </div>
                <h3 class="font-semibold text-brand-900 truncate">{t.title}</h3>
                {t.featured && <span class="text-[10px] text-accent-600">Featured on /wall</span>}
              </div>
              <svg class="w-4 h-4 text-earth-400 group-open:rotate-180 shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 border-t border-earth-100 pt-4">
              <p class="text-sm text-earth-600 mb-4 whitespace-pre-wrap">{t.body_markdown}</p>
              {t.status === 'rejected' ? (
                <p class="text-sm text-red-600 mb-4">This story was not approved. You may edit and resubmit.</p>
              ) : null}
              <form method="POST" class="space-y-3">
                <input type="hidden" name="id" value={t.id} />
                <input type="hidden" name="action" value="edit" />
                <input type="text" name="title" value={t.title} required class="w-full rounded-lg border border-earth-300 px-3 py-2 text-sm text-earth-900 focus:outline-none focus:ring-2 focus:ring-brand-500" />
                <textarea name="body_markdown" rows={4} required class="w-full rounded-lg border border-earth-300 px-3 py-2 text-sm text-earth-900 focus:outline-none focus:ring-2 focus:ring-brand-500 resize-y">{t.body_markdown}</textarea>
                <div class="flex gap-2">
                  <button type="submit" class="btn-primary text-xs px-3 py-1.5">Save & Resubmit</button>
                  <button type="submit" formmethod="POST" name="action" value="delete" class="text-xs px-3 py-1.5 text-red-600 hover:text-red-800" onclick="return confirm('Delete this story?')">
                    Delete
                  </button>
                </div>
              </form>
            </div>
          </details>
        ))}
      </div>
    ) : (
      <div class="bg-earth-50 rounded-xl p-12 text-center">
        <p class="text-earth-500 mb-6">You haven't written any testimonials yet.</p>
        <a href="/wall/submit" class="btn-primary">Share Your First Story</a>
      </div>
    )}
  </div>
</section>

</Layout>
