---
import Layout from '../layouts/Layout.astro';
import { getAuthFromRequest, type AuthUser } from '../utils/auth';
import { getDB } from '../utils/db';
import { env } from 'cloudflare:workers';
import { sendWelcomeEmail } from '../utils/email';

export const prerender = false;

const user = getAuthFromRequest(Astro.request, env);

if (!user) {
  return Astro.redirect('/sign-in');
}

let step = 1;
let message = '';
let action = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    action = formData.get('action')?.toString() || '';
    const db = getDB(env);
    const userId = user.id;

    if (action === 'save_location') {
      const city = formData.get('city')?.toString()?.trim();
      const state = formData.get('state')?.toString()?.trim()?.toUpperCase();
      if (city && state) {
        db.prepare('UPDATE users SET location_city = ?, location_state = ?, updated_at = datetime(\'now\') WHERE id = ?')
          .bind(city, state, userId).run();
        step = 2;
      } else {
        message = 'Please enter your city and state.';
      }
    }

    if (action === 'save_interest') {
      const interested = formData.get('interested')?.toString();
      const role = interested === 'yes' ? 'organizer' : undefined;
      if (role) {
        db.prepare('UPDATE users SET role = ?, updated_at = datetime(\'now\') WHERE id = ?')
          .bind(role, userId).run();
      }
      // Send welcome email
      sendWelcomeEmail(env, user.email, user.displayName).catch(() => {});
      return Astro.redirect('/dashboard?onboarded=1');
    }
  } catch (e) {
    message = 'Something went wrong. Please try again.';
  }
}

// Check if user already has location info
const hasLocation = user.location_city || user.location_state;
if (hasLocation && step === 1 && !action) {
  step = 2;
}
---

<Layout title="Welcome" description="Set up your profile to get started." user={user}>

<section class="section">
  <div class="max-w-lg mx-auto">
    <div class="text-center mb-10">
      <div class="w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center text-brand-700 font-bold text-xl mx-auto mb-4">
        {(user.displayName || 'You').charAt(0).toUpperCase()}
      </div>
      <h1 class="text-3xl font-display font-bold text-brand-900 mb-2">
        Welcome, {user.displayName?.split(' ')[0] || 'Friend'}!
      </h1>
      <p class="text-earth-500">
        {step === 1 ? "Let's get to know you a little." : "Almost done."}
      </p>
    </div>

    {message && (
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6 text-red-700 text-sm text-center">{message}</div>
    )}

    <!-- Progress dots -->
    <div class="flex justify-center gap-2 mb-10">
      <div class={`w-3 h-3 rounded-full ${step >= 1 ? 'bg-brand-600' : 'bg-earth-200'}`}></div>
      <div class={`w-3 h-3 rounded-full ${step >= 2 ? 'bg-brand-600' : 'bg-earth-200'}`}></div>
    </div>

    {step === 1 && (
      <div class="bg-white border border-earth-200 rounded-2xl p-8">
        <h2 class="text-xl font-display font-bold text-brand-900 mb-2">Where are you from?</h2>
        <p class="text-sm text-earth-500 mb-6">This helps us show you campaigns near you and connect you with local organizers.</p>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="save_location" />
          <div>
            <label for="city" class="block text-sm font-medium text-earth-700 mb-1.5">City *</label>
            <input type="text" id="city" name="city" required placeholder="e.g. Boulder" class="w-full rounded-lg border border-earth-300 px-4 py-2.5 text-earth-900 placeholder:text-earth-400 focus:outline-none focus:ring-2 focus:ring-brand-500" />
          </div>
          <div>
            <label for="state" class="block text-sm font-medium text-earth-700 mb-1.5">State *</label>
            <input type="text" id="state" name="state" required placeholder="e.g. CO" maxlength="2" class="w-full rounded-lg border border-earth-300 px-4 py-2.5 text-earth-900 placeholder:text-earth-400 focus:outline-none focus:ring-2 focus:ring-brand-500" />
          </div>
          <button type="submit" class="btn-primary w-full">Continue</button>
        </form>
        <p class="text-center text-xs text-earth-400 mt-4">
          <a href="/dashboard" class="text-brand-600 hover:text-brand-800">Skip for now</a>
        </p>
      </div>
    )}

    {step === 2 && (
      <div class="bg-white border border-earth-200 rounded-2xl p-8">
        <h2 class="text-xl font-display font-bold text-brand-900 mb-2">Ready to make change?</h2>
        <p class="text-sm text-earth-500 mb-6">
          Most people start by signing the national petition. But if you want to go further, you can start your own local campaign — targeting your HOA, city council, or county.
        </p>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="save_interest" />
          <div class="space-y-3">
            <label class="flex items-start gap-3 p-4 rounded-xl border-2 border-earth-200 cursor-pointer hover:border-brand-300 has-checked:border-brand-500 has-checked:bg-brand-50">
              <input type="radio" name="interested" value="yes" class="mt-1" checked />
              <div>
                <span class="font-semibold text-brand-900 text-sm">I want to organize a local campaign</span>
                <p class="text-xs text-earth-500 mt-1">Start a petition, gather signatures, present to your HOA or city council. We'll guide you step by step.</p>
              </div>
            </label>
            <label class="flex items-start gap-3 p-4 rounded-xl border-2 border-earth-200 cursor-pointer hover:border-brand-300 has-checked:border-brand-500 has-checked:bg-brand-50">
              <input type="radio" name="interested" value="later" class="mt-1" />
              <div>
                <span class="font-semibold text-brand-900 text-sm">I want to support existing campaigns first</span>
                <p class="text-xs text-earth-500 mt-1">Sign petitions, share stories, measure noise. You can always start a campaign later.</p>
              </div>
            </label>
          </div>
          <button type="submit" class="btn-primary w-full">Continue to Dashboard</button>
        </form>
        <p class="text-center text-xs text-earth-400 mt-4">
          <a href="/dashboard" class="text-brand-600 hover:text-brand-800">Skip for now</a>
        </p>
      </div>
    )}
  </div>
</section>

</Layout>
