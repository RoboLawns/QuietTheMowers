---
import Layout from '../../layouts/Layout.astro';
import { getAuthFromRequest, type AuthUser } from '../../utils/auth';
import { getDB } from '../../utils/db';
import { env } from 'cloudflare:workers';

export const prerender = false;

const user = getAuthFromRequest(Astro.request, env);
const db = getDB(env);
let campaigns: any[] = [];
let sigCount = 0;
let petSigned = 0;
let localCampaigns: any[] = [];

if (user) {
  try {
    const mc = db.prepare("SELECT c.*, (SELECT COUNT(*) FROM signatures WHERE campaign_id = c.id) as sigs FROM campaigns c WHERE c.organizer_id = ? ORDER BY c.created_at DESC").bind(user.id).all();
    campaigns = (mc.results || []) as any[];
    const s = db.prepare("SELECT COUNT(*) as c FROM signatures WHERE email = ?").bind(user.email).first() as any;
    petSigned = s?.c || 0;
    const g = db.prepare("SELECT COUNT(*) as c FROM signatures s JOIN campaigns c ON s.campaign_id = c.id WHERE c.organizer_id = ?").bind(user.id).first() as any;
    sigCount = g?.c || 0;
    if (user.location_state) {
      const l = db.prepare("SELECT c.*, u.display_name as oname, (SELECT COUNT(*) FROM signatures WHERE campaign_id = c.id) as sigs FROM campaigns c LEFT JOIN users u ON c.organizer_id = u.id WHERE c.location_state = ? AND c.status = 'active' AND c.organizer_id != ? ORDER BY c.created_at DESC LIMIT 4").bind(user.location_state, user.id).all();
      localCampaigns = (l.results || []) as any[];
    }
  } catch {}
}
---

<Layout title="Dashboard">
<section class="section">
  <div class="container-narrow">

    {user ? (
      <>
        <div class="flex items-center justify-between mb-10">
          <div>
            <h1 class="text-4xl font-display font-bold text-brand-900">Hi, {user.displayName || 'Friend'}</h1>
            {user.location_city && <p class="text-earth-500 mt-1">{user.location_city}, {user.location_state}</p>}
          </div>
          <div class="hidden sm:flex gap-3">
            <a href="/account" class="text-sm text-earth-500 hover:text-brand-700">Edit Profile</a>
            <a href="/sign-in" class="text-sm text-earth-500 hover:text-brand-700">Sign Out</a>
          </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
          <div class="bg-white border border-earth-200 rounded-xl p-4 text-center">
            <div class="text-2xl font-bold text-brand-600">{campaigns.length}</div>
            <div class="text-xs text-earth-500 mt-1">Campaigns</div>
          </div>
          <div class="bg-white border border-earth-200 rounded-xl p-4 text-center">
            <div class="text-2xl font-bold text-brand-600">{sigCount}</div>
            <div class="text-xs text-earth-500 mt-1">Sigs Gathered</div>
          </div>
          <div class="bg-white border border-earth-200 rounded-xl p-4 text-center">
            <div class="text-2xl font-bold text-brand-600">{petSigned}</div>
            <div class="text-xs text-earth-500 mt-1">Petitions Signed</div>
          </div>
          <div class="bg-white border border-earth-200 rounded-xl p-4 text-center">
            <a href="/campaigns/new" class="btn-accent text-xs px-4 py-2 w-full block text-center">Start New</a>
          </div>
        </div>

        <div class="bg-white border-2 border-accent-200 rounded-2xl p-6 mb-10">
          <h2 class="text-xl font-bold text-brand-900 mb-4">Your Next Action</h2>
          <div class="space-y-3">
            {!petSigned ? <a href="/petition" class="flex items-center justify-between p-3 rounded-lg bg-accent-50 hover:bg-accent-100"><div><div class="font-semibold text-accent-900 text-sm">Sign the National Petition</div><p class="text-xs text-earth-500">Show support for the movement (1 minute)</p></div><span class="text-accent-700 font-bold">&rarr;</span></a> : null}
            {campaigns.length === 0 && <a href="/campaigns/new" class="flex items-center justify-between p-3 rounded-lg bg-brand-50 hover:bg-brand-100"><div><div class="font-semibold text-brand-900 text-sm">Start a Local Campaign</div><p class="text-xs text-earth-500">Target your HOA, city, or county (15 min)</p></div><span class="text-brand-700 font-bold">&rarr;</span></a>}
            <a href="/measure/upload" class="flex items-center justify-between p-3 rounded-lg bg-earth-50 hover:bg-earth-100"><div><div class="font-semibold text-earth-900 text-sm">Upload Noise Measurements</div><p class="text-xs text-earth-500">Document the problem with data</p></div><span class="text-earth-700 font-bold">&rarr;</span></a>
            <a href="/wall/submit" class="flex items-center justify-between p-3 rounded-lg bg-earth-50 hover:bg-earth-100"><div><div class="font-semibold text-earth-900 text-sm">Share Your Story</div><p class="text-xs text-earth-500">Tell the world about your quiet morning</p></div><span class="text-earth-700 font-bold">&rarr;</span></a>
          </div>
        </div>

        {campaigns.length > 0 && (
          <div class="mb-10">
            <h2 class="text-xl font-bold text-brand-900 mb-4">My Campaigns</h2>
            <div class="space-y-3">
              {campaigns.map((c: any) => {
                const pct = Math.min(100, Math.round(((c.sigs || 0) / (c.goal_signatures || 1)) * 100));
                return (<a href={`/campaigns/${c.slug}/manage`} class="block bg-white border border-earth-200 rounded-xl p-5 hover:border-brand-300 hover:shadow-sm">
                  <div class="flex items-start justify-between mb-2"><h3 class="font-semibold text-brand-900">{c.title}</h3><span class={`text-xs px-2 py-0.5 rounded-full ${c.status === 'active' ? 'bg-green-100 text-green-700' : c.status === 'won' ? 'bg-accent-100 text-accent-700' : 'bg-earth-100 text-earth-600'}`}>{c.status}</span></div>
                  <p class="text-xs text-earth-500 mb-3">{c.target_name || c.location_city}</p>
                  <div class="flex items-center justify-between mb-2"><span class="text-sm text-earth-600">{c.sigs || 0} of {c.goal_signatures} signatures</span><span class="text-brand-600 text-sm font-medium">Manage &rarr;</span></div>
                  <div class="w-full bg-earth-200 rounded-full h-1.5"><div class="bg-brand-500 h-1.5 rounded-full" style={`width: ${pct}%`}></div></div>
                </a>);
              })}
            </div>
          </div>
        )}

        {localCampaigns.length > 0 && (
          <div class="mb-10">
            <h2 class="text-xl font-bold text-brand-900 mb-4">Campaigns in {user.location_state}</h2>
            <div class="grid sm:grid-cols-2 gap-3">
              {localCampaigns.map((c: any) => {
                const pct = Math.min(100, Math.round(((c.sigs || 0) / (c.goal_signatures || 1)) * 100));
                return (<a href={`/campaigns/${c.slug}`} class="block bg-white border border-earth-200 rounded-xl p-4 hover:border-brand-300">
                  <h3 class="font-semibold text-brand-900 text-sm mb-1">{c.title}</h3>
                  <p class="text-xs text-earth-500 mb-2">{c.location_city} &middot; by {c.oname || 'Organizer'}</p>
                  <div class="text-xs text-earth-600 mb-2">{c.sigs || 0} of {c.goal_signatures}</div>
                  <div class="w-full bg-earth-200 rounded-full h-1"><div class="bg-brand-500 h-1 rounded-full" style={`width: ${pct}%`}></div></div>
                </a>);
              })}
            </div>
          </div>
        )}
      </>
    ) : (
      <div class="bg-accent-50 border-2 border-accent-200 rounded-2xl p-12 text-center max-w-lg mx-auto">
        <div class="text-4xl mb-4">🌱</div>
        <h1 class="text-2xl font-display font-bold text-brand-900 mb-3">Welcome to Quiet The Mowers</h1>
        <p class="text-earth-500 mb-8">Sign in to start campaigns, sign petitions, and track your impact on your neighborhood.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/sign-in" class="btn-accent text-lg px-8 py-4">Sign In</a>
          <a href="/sign-up" class="btn-secondary text-lg px-8 py-4">Create Account</a>
        </div>
      </div>
    )}

  </div>
</section>
</Layout>
