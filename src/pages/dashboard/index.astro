---
import Layout from '../../layouts/Layout.astro';
import { getCurrentUser, type AuthUser } from '../../utils/auth';
import { getDB } from '../../utils/db';
import { env } from 'cloudflare:workers';

export const prerender = false;

const user = await getCurrentUser(Astro.locals, env) as AuthUser | null;

if (!user) {
  return new Response(null, { status: 302, headers: { Location: '/sign-in?redirect=/dashboard' } });
}

const db = getDB(env);

const myCampaigns = db.prepare(`
  SELECT c.*,
    (SELECT COUNT(*) FROM signatures WHERE campaign_id = c.id) as signature_count
  FROM campaigns c
  WHERE c.organizer_id = ?
  ORDER BY c.created_at DESC
`).bind(user.id).all();

const mySignatures = db.prepare(`
  SELECT s.*, c.title as campaign_title, c.slug as campaign_slug
  FROM signatures s
  LEFT JOIN campaigns c ON s.campaign_id = c.id
  WHERE s.email = ?
  ORDER BY s.created_at DESC
`).bind(user.email).all();

const totalSigsGathered = db.prepare(`
  SELECT COUNT(*) as count FROM signatures s
  JOIN campaigns c ON s.campaign_id = c.id
  WHERE c.organizer_id = ?
`).bind(user.id).first() as any;
---

<Layout title="Dashboard" description="Your personal campaign dashboard" user={user}>

<section class="section">
  <div class="container-narrow">
    <h1 class="text-4xl font-display font-bold text-brand-900 mb-2">Dashboard</h1>
    <p class="text-lg text-earth-500 mb-12">Welcome back, {user.displayName || 'Organizer'}.</p>

    <!-- Stats Bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-12">
      <div class="bg-white border border-earth-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-display font-bold text-brand-600">{myCampaigns.results?.length || 0}</div>
        <div class="text-xs text-earth-500 mt-1">Campaigns</div>
      </div>
      <div class="bg-white border border-earth-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-display font-bold text-brand-600">{totalSigsGathered?.count || 0}</div>
        <div class="text-xs text-earth-500 mt-1">Signatures Gathered</div>
      </div>
      <div class="bg-white border border-earth-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-display font-bold text-brand-600">{mySignatures.results?.length || 0}</div>
        <div class="text-xs text-earth-500 mt-1">Petitions Signed</div>
      </div>
      <div class="bg-white border border-earth-200 rounded-xl p-4 text-center">
        <a href="/campaigns/new" class="btn-accent text-xs px-4 py-2 w-full block text-center">
          Start New Campaign
        </a>
      </div>
    </div>

    <!-- My Campaigns -->
    <div class="mb-12">
      <h2 class="text-2xl font-display font-bold text-brand-900 mb-6">My Campaigns</h2>
      {Array.isArray(myCampaigns.results) && myCampaigns.results.length > 0 ? (
        <div class="grid sm:grid-cols-2 gap-4">
          {myCampaigns.results.map((c: any) => (
            <a href={`/campaigns/${c.slug}/manage`} class="block bg-white border border-earth-200 rounded-xl p-6 hover:border-brand-300 hover:shadow-sm transition-all">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-display font-bold text-brand-900">{c.title}</h3>
                <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${
                  c.status === 'active' ? 'bg-green-100 text-green-700' :
                  c.status === 'won' ? 'bg-accent-100 text-accent-700' :
                  c.status === 'draft' ? 'bg-earth-100 text-earth-600' :
                  'bg-earth-100 text-earth-600'
                }`}>{c.status}</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-earth-500">{c.signature_count || 0} of {c.goal_signatures} signatures</span>
                <span class="text-brand-600 text-sm font-medium">Manage &rarr;</span>
              </div>
              <div class="mt-3 w-full bg-earth-200 rounded-full h-1">
                <div class="bg-brand-500 h-1 rounded-full" style={`width: ${Math.min(100, ((c.signature_count || 0) / (c.goal_signatures || 1)) * 100)}%`}></div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="bg-earth-50 rounded-xl p-8 text-center">
          <p class="text-earth-500 mb-4">You haven't started any campaigns yet.</p>
          <a href="/campaigns/new" class="btn-primary">Start Your First Campaign</a>
        </div>
      )}
    </div>

    <!-- Petitions I've Signed -->
    <div class="mb-12">
      <h2 class="text-2xl font-display font-bold text-brand-900 mb-6">Petitions I've Signed</h2>
      {Array.isArray(mySignatures.results) && mySignatures.results.length > 0 ? (
        <div class="space-y-3">
          {mySignatures.results.map((s: any) => (
            <a href={s.campaign_slug ? `/campaigns/${s.campaign_slug}` : '#'} class="block bg-white border border-earth-200 rounded-xl p-4 hover:border-brand-300 transition-all">
              <div class="flex items-center justify-between">
                <div>
                  <div class="font-semibold text-earth-900 text-sm">{s.campaign_title || 'Campaign'}</div>
                  <div class="text-xs text-earth-400">Signed {new Date(s.created_at).toLocaleDateString()}</div>
                </div>
                {s.comment && <span class="text-xs text-earth-500 italic max-w-[200px] truncate">"{s.comment}"</span>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="bg-earth-50 rounded-xl p-8 text-center">
          <p class="text-earth-500">You haven't signed any petitions yet.</p>
          <a href="/campaigns" class="text-brand-600 font-medium text-sm hover:text-brand-800 mt-2 inline-block">Browse Campaigns &rarr;</a>
        </div>
      )}
    </div>

    <!-- Quick Links -->
    <div class="bg-white border border-earth-200 rounded-2xl p-8">
      <h2 class="text-xl font-display font-bold text-brand-900 mb-6">Quick Links</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/measure" class="block bg-earth-50 rounded-xl p-4 text-center hover:bg-brand-50 transition-colors">
          <div class="font-semibold text-brand-900 text-sm">Measure Noise</div>
          <div class="text-xs text-earth-500 mt-1">Rent a meter or upload data</div>
        </a>
        <a href="/ordinances" class="block bg-earth-50 rounded-xl p-4 text-center hover:bg-brand-50 transition-colors">
          <div class="font-semibold text-brand-900 text-sm">Ordinance Library</div>
          <div class="text-xs text-earth-500 mt-1">Find templates for your campaign</div>
        </a>
        <a href="/share" class="block bg-earth-50 rounded-xl p-4 text-center hover:bg-brand-50 transition-colors">
          <div class="font-semibold text-brand-900 text-sm">Shareable Assets</div>
          <div class="text-xs text-earth-500 mt-1">Yard signs, social tiles, posts</div>
        </a>
      </div>
    </div>
  </div>
</section>

</Layout>
